-- Lista para salvar os logs
local Logs = {}
local LogFile = "" -- Vai acumular os logs

-- Função para registrar log
local function AddLog(message)
    local timestamp = os.date("%H:%M:%S")
    local logEntry = string.format("[%s] %s", timestamp, message)
    table.insert(Logs, logEntry)
    LogFile = LogFile .. logEntry .. "\n"
    print(logEntry)
end

-- DETECTA QUANDO O PLAYER GANHA XP (qualquer aumento)
local function DetectXP()
    local leaderstats = Player:FindFirstChild("leaderstats")
    if not leaderstats then return end
    
    -- Procura por qualquer stat que possa ser XP
    for _, stat in pairs(leaderstats:GetChildren()) do
        if stat:IsA("NumberValue") or stat:IsA("IntValue") then
            local oldValue = stat.Value
            
            stat:GetPropertyChangedSignal("Value"):Connect(function()
                local newValue = stat.Value
                if newValue > oldValue then
                    AddLog(string.format("🔍 XP DETECTADO! Stat: %s | Antes: %d | Depois: %d", 
                        stat.Name, oldValue, newValue))
                    oldValue = newValue
                    
                    -- Agora vamos ver o que está por perto
                    ScanNearbyObjects()
                end
            end)
        end
    end
end

-- ESCANEIA OBJETOS PRÓXIMOS (para descobrir o que é a carne)
local function ScanNearbyObjects()
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    local root = character.HumanoidRootPart
    local radius = 15 -- Raio de busca após ganhar XP
    
    AddLog("🔍 Escaneando objetos próximos...")
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Parent ~= character then
            local distance = (root.Position - obj.Position).Magnitude
            if distance < radius then
                local info = string.format(
                    "📦 Objeto: '%s' | Classe: %s | Ancorado: %s | Tamanho: %.2f | Posição: %s | Distância: %.2f",
                    obj.Name,
                    obj.ClassName,
                    tostring(obj.Anchored),
                    obj.Size.Magnitude,
                    tostring(obj.Position),
                    distance
                )
                AddLog(info)
                
                -- Verifica se tem ClickDetector
                if obj:FindFirstChild("ClickDetector") then
                    AddLog("   ✅ TEM CLICKDETECTOR!")
                end
                
                -- Verifica se tem TouchTransmitter
                if obj:FindFirstChild("TouchTransmitter") then
                    AddLog("   ✅ TEM TOUCHTRANSMITTER!")
                end
                
                -- Verifica outros filhos importantes
                for _, child in pairs(obj:GetChildren()) do
                    if child:IsA("Script") or child:IsA("LocalScript") or child:IsA("ModuleScript") then
                        AddLog(string.format("   📜 Tem script: %s", child.Name))
                    end
                    if child:IsA("NumberValue") or child:IsA("StringValue") or child:IsA("BoolValue") then
                        AddLog(string.format("   💾 Tem Value: %s = %s", child.Name, tostring(child.Value)))
                    end
                end
            end
        end
    end
end

-- DETECTA INTERAÇÃO MANUAL (quando você clica em algo)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local mouse = Player:GetMouse()
        local target = mouse.Target
        
        if target then
            AddLog(string.format("🖱️ CLIQUEU EM: '%s' (%s) | Posição: %s", 
                target.Name, target.ClassName, tostring(target.Position)))
            
            -- Espera um pouco e vê se ganhou XP
            task.wait(0.5)
            
            -- Pega o objeto pai (pode ser um grupo)
            local parent = target.Parent
            if parent then
                AddLog(string.format("   📁 Pai: '%s' (%s)", parent.Name, parent.ClassName))
                
                -- Verifica se o pai tem algo relevante
                for _, child in pairs(parent:GetChildren()) do
                    if child:IsA("ClickDetector") then
                        AddLog("   ✅ PAI TEM CLICKDETECTOR!")
                    end
                end
            end
        end
    end
end)

-- DETECTA QUANDO VOCÊ TOCA EM ALGO
Character.HumanoidRootPart.Touched:Connect(function(hit)
    if hit and hit:IsA("BasePart") then
        AddLog(string.format("👣 TOCOU EM: '%s' (%s) | Ancorado: %s", 
            hit.Name, hit.ClassName, tostring(hit.Anchored)))
        
        -- Verifica o pai
        if hit.Parent then
            AddLog(string.format("   📁 Pai: '%s' (%s)", hit.Parent.Name, hit.Parent.ClassName))
        end
        
        -- Salva o objeto para análise
        if not DetectedItems[hit] then
            DetectedItems[hit] = {
                Name = hit.Name,
                Class = hit.ClassName,
                Parent = hit.Parent and hit.Parent.Name,
                Anchored = hit.Anchored,
                Size = hit.Size
            }
        end
    end
end)

-- DETECTA QUANDO OBJETOS SPAWNAM
workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("BasePart") and obj.Parent ~= Character then
        AddLog(string.format("✨ NOVO OBJETO SPAWNOU: '%s' (%s) | Posição: %s", 
            obj.Name, obj.ClassName, tostring(obj.Position)))
        
        if obj.Parent then
            AddLog(string.format("   📁 Pai: '%s' (%s)", obj.Parent.Name, obj.Parent.ClassName))
        end
        
        -- Verifica se parece uma carne (pequeno, não ancorado)
        if not obj.Anchored and obj.Size.Magnitude < 5 then
            AddLog("   🍖 PARECE SER UMA CARNE!")
            
            -- Tenta pegar informações adicionais
            task.wait(0.5)
            if obj.Parent then
                for _, child in pairs(obj:GetChildren()) do
                    if child:IsA("ClickDetector") then
                        AddLog("   ✅ TEM CLICKDETECTOR!")
                    end
                    if child:IsA("TouchTransmitter") then
                        AddLog("   ✅ TEM TOUCHTRANSMITTER!")
                    end
                end
            end
        end
    end
end)

-- DETECTA QUANDO OBJETOS SÃO REMOVIDOS (coletados)
workspace.DescendantRemoving:Connect(function(obj)
    if obj:IsA("BasePart") and obj.Parent ~= Character then
        AddLog(string.format("🗑️ OBJETO REMOVIDO: '%s' (%s)", obj.Name, obj.ClassName))
        
        if DetectedItems[obj] then
            AddLog("   ✅ ESTE OBJETO FOI TOCADO ANTES!")
            DetectedItems[obj] = nil
        end
    end
end)

